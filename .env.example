# Mike — example .env (secrets)
#
# This file is a template. The real .env is generated from Infisical by
# scripts/deploy.sh on ai-server and is NEVER committed. Use this file
# as the canonical list of secret keys that must exist in Infisical
# (project rule26/mike, env=prod) for the deploy to succeed.

# ── Supabase (Auth + Postgres) ───────────────────────────────────────────────
# Use Supabase's NEW key format (Publishable + Secret), not the deprecated
# legacy anon / service_role JWTs. Supabase dashboard → Project Settings →
# API Keys → "Publishable and secret API keys" tab. Mike's SDK versions
# (@supabase/supabase-js ^2.49 backend, ^2.81 frontend) support the new
# format natively; the upstream README's "use legacy" line is a transition-
# period leftover that contradicts even mike's own env var names.

# Project URL from Supabase dashboard
SUPABASE_URL=https://<project-id>.supabase.co
# Secret key (server-side, full DB access — equivalent role to old service_role)
SUPABASE_SECRET_KEY=<supabase-secret-key>

# Same URL exposed to the browser; also consumed at frontend build time
# (must be present at docker compose build for NEXT_PUBLIC_ bake-in)
NEXT_PUBLIC_SUPABASE_URL=https://<project-id>.supabase.co
# Publishable key (safe to ship in the client bundle — RLS-enforced)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=<supabase-publishable-key>

# ── Frontend → Backend wiring ────────────────────────────────────────────────
# Baked into the Next.js client bundle at build time. Browsers hitting
# mike-frontend on :8094 will fetch the backend at this URL.
NEXT_PUBLIC_API_BASE_URL=http://10.77.1.181:8095

# ── Object storage (Cloudflare R2 or any S3-compatible) ──────────────────────
R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=<r2-access-key-id>
R2_SECRET_ACCESS_KEY=<r2-secret-access-key>

# ── AI providers (at least one required) ─────────────────────────────────────
ANTHROPIC_API_KEY=<anthropic-api-key>
# Optional providers
# GEMINI_API_KEY=<gemini-api-key>
# OPENAI_API_KEY=<openai-api-key>

# ── Email (optional; required for Supabase confirmation/reset flows) ─────────
# RESEND_API_KEY=<resend-api-key>

# ── Internal secrets (generate with: openssl rand -hex 32) ───────────────────
DOWNLOAD_SIGNING_SECRET=<32-byte-hex>
USER_API_KEYS_ENCRYPTION_SECRET=<32-byte-hex>
